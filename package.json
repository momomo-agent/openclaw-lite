{
  "name": "paw",
  "version": "0.22.0",
  "description": "Portable local AI assistant with multi-agent chat",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite & electron . --dev",
    "build": "vite build",
    "dist": "npm run build && electron-builder --mac",
    "dist:notarize": "npm run build && electron-builder --mac && bash scripts/notarize.sh",
    "dbb": "node .ai/dbb/dbb-test.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node test/e2e/run.mjs",
    "start:e2e": "electron . --e2e-port=9222"
  },
  "author": "momomo-agent",
  "license": "MIT",
  "build": {
    "appId": "com.momomo.paw",
    "productName": "Paw",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "files": [
      "main.js",
      "preload.js",
      "session-store.js",
      "memory-index.js",
      "renderer/**/*",
      "assets/**/*",
      "tools/**/*",
      "skills/**/*",
      "core/**/*",
      "templates/**/*",
      "package.json"
    ],
    "dmg": {
      "title": "Paw"
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^38.8.6",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "acpx": "^0.1.15",
    "better-sqlite3": "^12.6.2",
    "croner": "^10.0.1",
    "linkedom": "^0.18.12",
    "marked-highlight": "^2.2.3",
    "node-llama-cpp": "^3.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tinyexec": "^1.0.4"
  }
}
